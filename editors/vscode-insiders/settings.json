{
  "files.autoSave": "afterDelay",

  // Theming Setup
  "workbench.colorTheme": "Orbi Blue",
  "workbench.iconTheme": "material-icon-theme",

  // Theming Style
  "editor.fontFamily": "Cartograph CF",
  "editor.fontWeight": "200",
  "editor.fontLigatures": true,
  "editor.fontSize": 17,
  "editor.lineHeight": 1.4,
  "window.zoomLevel": 0.65,
  "editor.cursorBlinking": "smooth",
  "editor.semanticHighlighting.enabled": false,
  "editor.formatOnSave": true,
  "workbench.startupEditor": "none",
  "workbench.editor.wrapTabs": false,
  "breadcrumbs.enabled": false,
  "window.menuBarVisibility": "toggle",

  // Editor
  "editor.tabSize": 2,
  "editor.linkedEditing": true,
  "editor.mouseWheelZoom": true,
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": false,
  "editor.detectIndentation": true,
  "editor.renderWhitespace": "none",
  "editor.snippetSuggestions": "top",
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.scrollbar.verticalScrollbarSize": 0,
  "editor.scrollbar.horizontalScrollbarSize": 1,
  "editor.bracketPairColorization.enabled": true,
  "files.defaultLanguage": "${activeEditorLanguage}",
  "editor.glyphMargin": false, // comment out to "ON"
  // "editor.folding": false, // comment out to "ON"

  // Explorer
  "explorer.openEditors.visible": 1,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.enabled": true,

  // terminal
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.external.linuxExec": "/usr/bin/alacritty",
  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",

  // extensions : git
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "never",
  "diffEditor.ignoreTrimWhitespace": false,

  // theme customization
  "editor.tokenColorCustomizations": {
    "[Just Black]": {
      "comments": "#c1cec4"
    }
  },

  // extensions : prettier

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },

  // extensions : Languages (C++)
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },

  // extensions : Languages (JS)
  "javascript.updateImportsOnFileMove.enabled": "always",

  // extensions : Vim
  "vim.leader": "<space>",
  "vim.easymotion": true,
  "vim.startInInsertMode": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.foldfix": true,

  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<esc>"]
    }
  ],

  "vim.normalModeKeyBindings": [
    {
      "before": ["<leader>", "a"],
      "commands": ["vscode-harpoon.addEditor"]
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["vscode-harpoon.editEditors"]
    },
    {
      "before": ["<leader>", "p"],
      "commands": ["vscode-harpoon.editorQuickPick"]
    },
    {
      "before": ["<leader>", "1"],
      "commands": ["vscode-harpoon.gotoEditor1"]
    },
    {
      "before": ["<leader>", "2"],
      "commands": ["vscode-harpoon.gotoEditor2"]
    },
    {
      "before": ["<leader>", "3"],
      "commands": ["vscode-harpoon.gotoEditor3"]
    }
  ],

  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "n"],
      "commands": [":nohl"]
    },
    {
      "before": ["<leader>", "w"],
      "commands": ["workbench.action.splitEditor"]
    },
    {
      "before": ["<leader>", "t"],
      "commands": ["workbench.action.toggleSidebarVisibility"]
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["revealInExplorer"]
    },
    {
      "before": ["<leader>", "/"],
      "commands": ["editor.action.commentLine"]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": ["i"],
      "after": ["<Esc>", "i"]
    },
    {
      "before": ["<leader>", "/"],
      "commands": ["editor.action.commentLine", "extension.vim_escape"]
    }
  ],

  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    "<C-d>": false,
    "<C-c>": false,
    "<C-x>": false,
    "<C-v>": false
  }
}
